# ──────────────────────────────────────────────────────────────────────
# Learning Tracker - Environment Variables
# Copy this to .env and fill in your values. NEVER commit .env to git.
# ──────────────────────────────────────────────────────────────────────

# App URL (used for CORS / links)
APP_URL="http://localhost:3000"

# ── Auth (REQUIRED in production) ──────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CHANGE_ME_generate_a_random_64_char_hex_string"
ADMIN_JWT_SECRET="CHANGE_ME_generate_a_different_random_64_char_hex_string"

# ── Admin ───────────────────────────────────────────────────────────────
ADMIN_PASSWORD="change-me-before-going-public"

# ── Database ────────────────────────────────────────────────────────────
# Supabase / Render / Neon / any PostgreSQL connection string
DATABASE_URL="postgresql://postgres:password@db.supabase.com:5432/postgres"